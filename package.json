{
  "name": "marketplace",
  "version": "1.0.0",
  "description": "Multi-vendor marketplace MVP",
  "main": "dist/index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "api:lint": "redocly lint api/openapi.yaml",
    "api:types": "openapi-typescript api/openapi.yaml -o src/types/api.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.44.1",
    "express": "^4.21.2",
    "jose": "^5.10.0",
    "postgres": "^3.4.5",
    "stripe": "^22.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@redocly/cli": "^1.25.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.17.0",
    "openapi-typescript": "^7.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
