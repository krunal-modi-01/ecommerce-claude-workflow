{
  "permissions": {
    "allow": ["Read", "Glob", "Grep",
      "Bash(npm ci)", "Bash(npm run lint:*)", "Bash(npm test:*)",
      "Bash(npm run typecheck)", "Bash(npm run db:migrate)",
      "Bash(git status)", "Bash(git diff:*)", "Bash(git add:*)", "Bash(git commit:*)"],
    "ask": ["Bash(git push:*)", "Bash(docker:*)", "Bash(npm run db:migrate:prod)"],
    "deny": ["Read(./.env)", "Read(./.env.*)", "Read(./secrets/**)", "Bash(rm -rf:*)"]
  },
  "hooks": {
    "Stop": [{ "matcher": "",
      "hooks": [{ "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/verify.sh" }] }]
  }
}